{
  "name": "@infino-ai/memory-infino",
  "version": "0.1.0",
  "description": "Infino-backed long-term memory for OpenClaw — hybrid (BM25+vector) recall and SQL over memory, on object storage.",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "engines": {
    "node": ">=18"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.6.8"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test",
    "eval:locomo": "npm run build && node eval/run-locomo.mjs"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@infino-ai/infino": "^0.1.0",
    "typebox": "^1.2.14"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "devDependencies": {
    "@types/node": "^20",
    "openclaw": "^2026.6.8",
    "typescript": "^5"
  }
}
